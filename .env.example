# AI Code Review Agent Configuration
# Copy this file to .env and fill in your values

# ── API Key (Required) ──────────────────────────────────────────────────────
# Set at least one API key. The agent supports multiple providers:
DASHSCOPE_API_KEY=sk-your-dashscope-key-here
# DEEPSEEK_API_KEY=sk-your-deepseek-key-here
# OPENAI_API_KEY=sk-your-openai-key-here

# ── Custom API Endpoint (Optional) ──────────────────────────────────────────
# Use any OpenAI-compatible endpoint. Overrides auto-detection.
# API_URL=https://your-custom-endpoint/v1/chat/completions

# ── Model Selection (Optional) ──────────────────────────────────────────────
REVIEWER_MODEL=qwen-max
FIXER_MODEL=qwen-max
TESTER_MODEL=qwen-plus
VERIFIER_MODEL=qwen-plus

# ── LLM Parameters (Optional) ──────────────────────────────────────────────
MAX_TOKENS=4096
TEMPERATURE=0.3

# ── Review Parameters (Optional) ───────────────────────────────────────────
MAX_FILES_PER_RUN=20

# ── API Settings (Optional) ────────────────────────────────────────────────
API_TIMEOUT=300
MAX_RETRIES=5
